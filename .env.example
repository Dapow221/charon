TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# Helius RPC — required for Solana log streaming and wallet history
HELIUS_API_KEY=
SOLANA_RPC_URL=
SOLANA_WS_URL=
WATCH_PUMP_AMM=false

APP_NAME=Charon Alerts
DB_PATH=./charon-alerts.sqlite
SEND_STARTUP_MESSAGE=false

# Token enrichment
JUPITER_ENABLED=true
JUPITER_CACHE_TTL_MS=30000
WALLET_PROFILE_CACHE_TTL_MS=600000
WALLET_HISTORY_LIMIT=50

# Pump.fun fee claim alerts
CLAIMABLE_FEES_MIN_SOL=2

# Low-tx wallet profiling only; fresh buys do not alert by themselves
FRESH_MAX_TX_COUNT=5
FRESH_MAX_WALLET_AGE_MINUTES=1440
OLD_FRESH_MIN_FUNDING_AGE_HOURS=24

# Dead-token revival alerts
DEAD_TOKEN_MIN_AGE_DAYS=3
DEAD_TOKEN_BUY_MIN_SOL=5
DEAD_TOKEN_SPIKE_WINDOW_MINUTES=10
DEAD_TOKEN_SPIKE_MIN_SOL=5
DEAD_TOKEN_SPIKE_MIN_BUYERS=2

# Wallet context for dormant/dead-token alerts
DORMANT_BUY_MIN_SOL=3
BIG_DORMANT_BUY_MIN_SOL=7
SEMI_DORMANT_BUY_MIN_SOL=1
DORMANT_DAYS=4
VERY_DORMANT_DAYS=8
SEMI_DORMANT_DAYS=2
SEMI_DORMANT_LOW_MCAP_MAX_USD=1000000
DORMANT_INFLOW_WALLET_COUNT=5
DORMANT_INFLOW_WINDOW_MINUTES=120
DORMANT_DEPLOY_DAYS=4

# Wallet quality alerts
BIG_PNL_MIN_USD=50000
WHALE_BUY_SOL=15
DOLPHIN_BUY_SOL=5
